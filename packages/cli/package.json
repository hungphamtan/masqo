{
  "name": "@masqo/cli",
  "version": "0.1.1",
  "description": "Local secret redaction engine — detect and mask API keys, tokens, and passwords before they leak",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "bin": {
    "masqo": "bin/masqo.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@masqo/engine": "^0.1.0",
    "@masqo/shared": "^0.1.0",
    "@types/react": "^19.2.17",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^7.0.6",
    "ora": "^8.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
