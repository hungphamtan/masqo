{
  "name": "@masqo/extension",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build && CONTENT_ENTRY=chatgpt vite build --config vite.content.config.mts && CONTENT_ENTRY=claude vite build --config vite.content.config.mts && CONTENT_ENTRY=gemini vite build --config vite.content.config.mts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@masqo/engine": "file:../engine",
    "@masqo/shared": "file:../shared",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vitest": "^1.2.1"
  }
}
