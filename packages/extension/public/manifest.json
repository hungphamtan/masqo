{
  "manifest_version": 3,
  "name": "Masqo - Secret Redaction",
  "version": "0.1.2",
  "description": "Detect and redact secrets before pasting into AI chat tools. All processing runs locally - no data leaves your browser.",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://perplexity.ai/*",
    "https://manus.im/*",
    "https://poe.com/*",
    "https://copilot.microsoft.com/*",
    "https://you.com/*",
    "https://character.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://perplexity.ai/*",
        "https://manus.im/*",
        "https://poe.com/*",
        "https://copilot.microsoft.com/*",
        "https://you.com/*",
        "https://character.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Masqo"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/sidebar/index.html", "assets/*", "chunks/*"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://perplexity.ai/*",
        "https://manus.im/*",
        "https://poe.com/*",
        "https://copilot.microsoft.com/*",
        "https://you.com/*",
        "https://character.ai/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
